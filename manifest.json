{
  "manifest_version": 3,
  "name": "url-reading-tracker",
  "version": "1.0",

  "description": "Tracks all URLs that one have read",

  "browser_specific_settings": {
    "gecko": {
      "id": "url-reading-tracker@mozilla.org",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["track.js"]
    }
  ]
}
